{
  "name": "devkit",
  "version": "0.1.0",
  "description": "Local dev environment manager — SSL, custom domains, mail",
  "type": "module",
  "bin": {
    "devkit": "./bin/devkit.js"
  },
  "scripts": {
    "dev": "echo '⚠ Este es el repositorio de devkit. Para crear un proyecto usa: devkit new mi-proyecto'",
    "build": "node build.mjs",
    "build:bundle": "esbuild bin/devkit.js --bundle --platform=node --format=cjs --outfile=dist/bundle.cjs --external:electron --log-level=warning",
    "build:compile": "pkg dist/bundle.cjs --out-path dist/bin --compress GZip"
  },
  "pkg": {
    "assets": [
      "templates/**"
    ],
    "targets": [
      "node20-macos-arm64",
      "node20-macos-x64",
      "node20-linux-x64",
      "node20-win-x64"
    ]
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "conf": "^13.0.0",
    "execa": "^9.3.0",
    "ora": "^8.1.0"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.19.0",
    "esbuild": "^0.28.0"
  }
}
